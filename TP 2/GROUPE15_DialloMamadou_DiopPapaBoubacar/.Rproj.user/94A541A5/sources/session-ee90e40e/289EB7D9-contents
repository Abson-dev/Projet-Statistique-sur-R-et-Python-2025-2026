#  7. TABLEAU RÉCAPITULATIF                                       #
# ══════════════════════════════════════════════════════════════ #
```{r}
data %>%
  select(zone, sexe, age, educ) %>%
  tbl_summary(
    by        = zone,
    label     = list(age ~ "Âge", sexe ~ "Sexe", educ ~ "Niveau d'éducation"),
    statistic = list(all_continuous()  ~ "{mean} ({sd})",
                     all_categorical() ~ "{n} ({p}%)"),
    missing   = "no"
  ) %>%
  add_p() %>%
  add_overall() %>%
  as_gt() %>%
  gt::gtsave("output/tables/tableau_recapitulatif.html")
```
# COMMENTAIRE — Tableau récapitulatif (gtsummary) :
# Ce tableau de synthèse compare les caractéristiques sociodémographiques
# (âge moyen, répartition par sexe, distribution du niveau d'éducation)
# entre les zones rurale et urbaine, ainsi que pour l'ensemble de l'échantillon
# (colonne "Overall"). Les p-valeurs (add_p) indiquent pour chaque variable
# si la différence rural/urbain est statistiquement significative.
# C'est la table à présenter en premier dans un rapport : elle donne une vue
# d'ensemble de la composition de l'échantillon et pose le contexte de
# toutes les analyses suivantes.