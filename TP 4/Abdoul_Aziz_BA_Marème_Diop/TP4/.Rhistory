parcelles <- parcelles %>%
mutate(
superficie_ha = case_when(
s11aq4b == 1 ~ as.numeric(s11aq4aa) * heaps,
s11aq4b == 2 ~ as.numeric(s11aq4aa) * ridges,
s11aq4b == 3 ~ as.numeric(s11aq4aa) * stands,
s11aq4b == 5 ~ as.numeric(s11aq4aa) * 0.404686,
s11aq4b == 6 ~ as.numeric(s11aq4aa) * 1.0,
s11aq4b == 7 ~ as.numeric(s11aq4aa) / 10000,
TRUE         ~ NA_real_
)
)
# ── 3. Superficie totale par ménage ───────────────────────────
menages <- parcelles %>%
group_by(hhid) %>%
summarise(
superficie_totale_ha = sum(superficie_ha, na.rm = TRUE),
n_parcelles          = n(),
.groups = "drop"
)
# ── 4. Contrôle qualité ───────────────────────────────────────
sum(is.na(parcelles$superficie_ha))        # manquants
parcelles %>% filter(superficie_ha < 0) %>% nrow()    # négatifs
parcelles %>% filter(superficie_ha > 500) %>% nrow()  # aberrants
# ── Fusionner les poids ──────────────────────────────────────
poids <- couverture %>%
select(hhid, wt_wave4, wt_longpanel, strata, cluster = ea)
parcelles <- parcelles %>%
left_join(poids, by = "hhid")
menages <- menages %>%
left_join(poids, by = "hhid")
# ── Sauvegarde ───────────────────────────────────────────────
# Les poids sont inclus dans les fichiers sauvegardés
saveRDS(parcelles, "data/processed/parcelles.rds")
saveRDS(menages,   "data/processed/menages.rds")")
