# Distribution des types de maladies

```{r maladies}
data_maladie <- data %>%
  mutate(type_maladie = as_factor(s4aq3b_1)) %>%
  filter(!is.na(type_maladie), !is.na(wt_wave4))

top_maladies <- data_maladie %>%
  group_by(type_maladie) %>%
  summarise(
    n_pondere = sum(wt_wave4),
    .groups = "drop"
  ) %>%
  arrange(desc(n_pondere)) %>%
  slice_head(n = 10) %>%
  mutate(
    proportion = n_pondere / sum(n_pondere),
    proportion_pct = percent(proportion, accuracy = 0.1)
  )

# Tableau des 10 principales maladies
top_maladies %>%
  select(type_maladie, n_pondere, proportion_pct) %>%
  kable(
    col.names = c("Type de maladie", "Nombre de cas pondéré", "Proportion"),
    caption = "Top 10 des maladies déclarées (pondéré)"
  )

```


## Visualisation des principales maladies

```{r plot-maladies}
ggplot(top_maladies,
       aes(x = n_pondere, y = reorder(type_maladie, n_pondere))) +
  geom_col(fill = "steelblue", alpha = 0.8) +
  geom_text(aes(label = round(n_pondere, 0)), hjust = -0.2, size = 3.5) +
  labs(
    x = "Nombre de cas pondéré",
    y = "",
    title = "Top 10 des maladies déclarées",
    caption = "Source: Enquête Harvest W4"
  ) +
  theme_minimal() +
  theme(plot.title = element_text(face = "bold", hjust = 0.5)) +
  xlim(0, max(top_maladies$n_pondere) * 1.1)
```

Ce graphique nous montre les 10 maladies les plus déclarées dans la population. La malaria est la maladie la plus déclarée avec un effectif de 11374772 individus.

# Analyse des dépenses de santé

```{r depenses, warning=TRUE}
# Vérification de l'existence de la variable
if("s4aq9" %in% names(data)) {
  
  p2 <- ggplot(data %>% filter(!is.na(s4aq9), !is.na(wt_wave4)),
               aes(x = s4aq9, weight = wt_wave4)) +
    geom_histogram(binwidth = 5000, fill = "darkblue", color = "black", alpha = 0.7) +
    scale_y_log10() +
    labs(
      title = "Distribution des dépenses de santé (échelle log sur effectifs pondérés)",
      x = "Dépenses de santé (FCFA)",
      y = "Effectif pondéré (échelle log)"
    ) +
    theme_minimal()

  p2
  
  # Statistiques descriptives pondérées
  data %>%
    filter(!is.na(s4aq9), !is.na(wt_wave4)) %>%
    summarise(
      effectif = n(),
      effectif_pondere = sum(wt_wave4),
      moyenne = weighted.mean(s4aq9, wt_wave4),
      mediane = Hmisc::wtd.quantile(s4aq9, weights = wt_wave4, probs = 0.5),
      q1 = Hmisc::wtd.quantile(s4aq9, weights = wt_wave4, probs = 0.25),
      q3 = Hmisc::wtd.quantile(s4aq9, weights = wt_wave4, probs = 0.75),
      min = min(s4aq9),
      max = max(s4aq9)
    ) %>%
    mutate(across(where(is.numeric), ~round(., 0))) %>%
    kable(caption = "Statistiques descriptives pondérées des dépenses de santé")
  
} else {
  cat(" La variable s4aq9 (dépenses de santé) n'est pas disponible dans les données.")
}

```

L'histogramme nous montre que malgré la log-transformation, la part des dépenses inférieures à 20000 est toujours importante par rapport à celle des dépenses supérieures à 20000.

## Statistiques par décile des dépenses

```{r deciles-depenses}
if("s4aq9" %in% names(data)) {
  stats_deciles <- data %>%
    filter(!is.na(s4aq9), !is.na(wt_wave4)) %>%
    mutate(
      decile = Hmisc::cut2(s4aq9, g = 10)
    ) %>%
    group_by(decile) %>%
    summarise(
      n = n(),
      poids_total = sum(wt_wave4),
      moyenne = weighted.mean(s4aq9, wt_wave4),
      mediane = Hmisc::wtd.quantile(s4aq9, weights = wt_wave4, probs = 0.5),
      q1 = Hmisc::wtd.quantile(s4aq9, weights = wt_wave4, probs = 0.25),
      q3 = Hmisc::wtd.quantile(s4aq9, weights = wt_wave4, probs = 0.75),
      sd = sqrt(Hmisc::wtd.var(s4aq9, weights = wt_wave4)),
      .groups = "drop"
    ) %>%
    mutate(
      decile_label = as.character(decile)
    )
  
  # Affichage du tableau
  stats_deciles %>%
    select(decile_label, n, moyenne, mediane, q1, q3, sd) %>%
    mutate(across(where(is.numeric), ~round(., 0))) %>%
    kable(
      col.names = c("Décile", "n", "Moyenne", "Médiane", "Q1", "Q3", "Écart-type"),
      caption = "Statistiques pondérées des dépenses de santé par décile"
    )
  
  # Visualisation
  stats_deciles %>%
    ggplot(aes(x = decile_label, y = moyenne)) +
    geom_col(fill = "darkorange", alpha = 0.7) +
    geom_errorbar(aes(ymin = moyenne - sd, ymax = moyenne + sd), width = 0.2) +
    labs(
      title = "Dépenses moyennes de santé par décile (± écart-type, pondéré)",
      x = "Décile",
      y = "Dépenses moyennes (FCFA)"
    ) +
    theme_minimal() +
    theme(axis.text.x = element_text(angle = 45, hjust = 1))
  
} else {
  cat("Analyse par décile non disponible : variable s4aq9 manquante")
}
```

Ce graphique nous montre les dépenses moyennes de santé par décile. 

# Tests d'indépendance

## Importation et préparation des données de consommation

```{r preparation-tests}
# Chargement des données de consommation
data_cons <- read_stata("../data/raw/totcons_final.dta")

# Construction des quintiles
data_cons <- data_cons %>%
  mutate(quintile = ntile(totcons_adj_norm, 5))

# Fusion avec la base data
data <- data %>%
  left_join(data_cons %>% select(hhid, quintile), by = "hhid")

tab <- table(
  as_factor(data$quintile),
  as_factor(data$s4aq1)
)
tab
chisq.test(tab)
cramer_v(tab)
```


Le tableau ci-dessus présente la répartition des consultations selon le quintile de consommation.