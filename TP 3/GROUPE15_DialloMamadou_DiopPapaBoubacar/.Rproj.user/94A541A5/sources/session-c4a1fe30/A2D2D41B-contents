# Importation des données

```{r importation}
# Chargement des données de morbidité
data <- read_stata("../data/raw/sect4a_harvestw4.dta")

# Chargement et préparation des données sociodémographiques
data_to_join <- read_stata("../data/raw/sect1_harvestw4.dta")
data_to_join <- data_to_join %>% select(hhid, indiv, s1q2, s1q4)

# Jointure
data <- inner_join(data, data_to_join, by = c("hhid", "indiv"))

data_to_join <- read_stata("../data/raw/secta_harvestw4.dta")
data_to_join <- data_to_join %>% select(hhid, wt_wave4)

data <- data %>%
  left_join(data_to_join %>% select(hhid, wt_wave4), by = "hhid")

data <- data %>% filter(!is.na(wt_wave4))

```


# Taux de morbidité global

```{r taux-global}
taux_global <- data %>% 
  summarise(
    taux_de_morbidite = weighted.mean(s4aq3 == 1, wt_wave4, na.rm = TRUE),
    .groups = "drop"
  )

taux_global %>%
  mutate(taux_de_morbidite = scales::percent(taux_de_morbidite, accuracy = 0.1)) %>%
  kable(
    col.names = "Taux de morbidité global",
    caption = "Taux de morbidité dans la population (pondéré)"
  )
```
Le taux de morbidité affiché est de 8,7% dans la population, c'est-à-dire 9,3% des individus de la population ont déclarés être malade ou blessé.

# Préparation des données pour l'analyse

```{r preparation}
data_morb <- data %>%
  mutate(
    malade = ifelse(s4aq3 == 1, 1, 0),
    sexe = as_factor(s1q2),
    age = s1q4,
    groupe_age = cut(
      age,
      breaks = c(0, 5, 15, 25, 45, 65, Inf),
      right = FALSE,
      labels = c("0-4 ans", "5-14 ans", "15-24 ans", "25-44 ans", "45-64 ans", "65 ans et plus")
    )
  ) %>%
  filter(!is.na(malade), !is.na(sexe), !is.na(groupe_age), !is.na(wt_wave4))

taux_global <- data_morb %>%
  summarise(
    taux_de_morbidite = weighted.mean(malade, wt_wave4)
  )
taux_global
```


# Analyse par sexe

## Taux de morbidité par sexe avec intervalle de confiance

```{r morbidite-par-sexe}
library(dplyr)
library(survey)
library(scales)
library(knitr)

# plan de sondage simple avec poids
design_morb <- svydesign(
  ids = ~1,
  weights = ~wt_wave4,
  data = data_morb
)

# proportion pondérée par sexe
tab_sexe <- svyby(
  ~malade,
  ~sexe,
  design = design_morb,
  svyciprop,
  vartype = c("ci"),
  method = "logit",
  na.rm = TRUE
) %>%
  as.data.frame() %>%
  mutate(
    proportion_pct = percent(malade, accuracy = 0.1),
    IC = paste0(
      "[", percent(ci_l, accuracy = 0.1),
      " ; ", percent(ci_u, accuracy = 0.1), "]"
    )
  )

# affichage
tab_sexe %>%
  select(sexe, proportion_pct, IC) %>%
  kable(
    col.names = c("Sexe", "Proportion pondérée", "IC à 95%"),
    caption = "Taux de morbidité par sexe (pondéré)"
  )
```
Le tableau ci-dessus montre que le taux de morbidité est de 8,2% dans la sous-population des individus de sexe masculin tandis qu'il est de 9,2% dans les individus de sexe féminin.

## Visualisation

```{r plot-sexe}
ggplot(tab_sexe, aes(x = sexe, y = malade)) +
  geom_col(fill = "steelblue", alpha = 0.8) +
  geom_errorbar(aes(ymin = ci_l, ymax = ci_u), width = 0.2, color = "darkblue") +
  scale_y_continuous(labels = percent_format(accuracy = 1)) +
  labs(
    x = "Sexe",
    y = "Taux de morbidité",
    title = "Taux de morbidité par sexe avec intervalle de confiance à 95%"
  ) +
  theme_minimal() +
  theme(plot.title = element_text(face = "bold", hjust = 0.5))
```

