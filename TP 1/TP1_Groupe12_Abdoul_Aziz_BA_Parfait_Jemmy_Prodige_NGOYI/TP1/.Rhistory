# Génération du tableau descriptif avec data_traite
tableau_final <- data_traite %>%
select(sector, s1q4, sexe, taille_men) %>%
tbl_summary(
by = sector, # Comparaison Urbain vs Rural
percent = "column",
statistic = list(
all_continuous() ~ "{mean} ({sd})",
all_categorical() ~ "{n} ({p}%)"
),
label = list(
s1q4 ~ "Âge du chef de ménage",
sexe ~ "Sexe du chef de ménage",
taille_men ~ "Taille du ménage"
),
missing = "no"
) %>%
add_p(
# Application du test de Wilcoxon pour les variables numériques
# et du Chi-deux pour le sexe
test = list(
c(s1q4, taille_men) ~ "wilcox.test",
sexe ~ "chisq.test"
),
pvalue_fun = ~style_pvalue(.x, digits = 3)
) %>%
add_overall(last = FALSE, col_label = "**National**") %>%
modify_header(label = "**Indicateurs**") %>%
bold_labels() %>%
italicize_levels()
