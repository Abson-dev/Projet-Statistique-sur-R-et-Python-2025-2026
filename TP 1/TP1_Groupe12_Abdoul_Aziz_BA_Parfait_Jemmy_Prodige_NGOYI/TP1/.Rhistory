lower_bound <- Q1 - 1.5 * IQR
upper_bound <- Q3 + 1.5 * IQR
# Identifier les valeurs aberrantes
outliers <- data_traite$s1q4[data_traite$s1q4 < lower_bound | data_traite$s1q4 > upper_bound]
outliers
# remplassement par NAs
data_traite$s1q4 <- ifelse(data_traite$s1q4 < lower_bound | data_traite$s1q4 > upper_bound,
NA, data_traite$s1q4)
