# Calcul de r (taille d'effet)
n1 <- sum(data_traite$sector == "Rural")
n2 <- sum(data_traite$sector == "Urbain")
N <- n1 + n2
W = 57208581
# Approximation de Z à partir de W
Z <- (W - (n1*n2)/2) / sqrt(n1*n2*(n1+n2+1)/12)
r <- abs(Z) / sqrt(N)
cat("Taille d'effet (r) =", round(r, 3))
