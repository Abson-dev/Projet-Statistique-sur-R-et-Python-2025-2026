total <- nrow(data)
resultats_parente <- data %>%
filter(!is.na(s1q3)) %>%
count(s1q3, name = "effectif") %>%
mutate(
proportion = effectif / total,
proportion_pct = scales::percent(proportion, accuracy = 0.1),
IC_lower = sapply(effectif, function(x) scoreci(x, total, conf.level = 0.95)$conf.int[1]),
IC_upper = sapply(effectif, function(x) scoreci(x, total, conf.level = 0.95)$conf.int[2]),
IC_text = paste0("[", scales::percent(IC_lower, accuracy = 0.1), " ; ",
scales::percent(IC_upper, accuracy = 0.1), "]")
)
# Affichage du tableau
resultats_parente %>%
select(s1q3, effectif, proportion_pct, IC_text) %>%
rename(
`Lien de parenté` = (s1q3),
Effectif = effectif,
Proportion = proportion_pct,
`IC 95%` = IC_text
)
# Visualisation avec IC
resultats_parente %>%
ggplot(aes(x = proportion, y = fct_reorder(as_factor(s1q3), proportion))) +
geom_col(fill = "darkblue") +
geom_errorbar(aes(xmin = IC_lower, xmax = IC_upper), width = 0.2) +
labs(
title = "Proportions des liens de parenté avec IC à 95%",
x = "Proportion",
y = ""
) +
scale_x_continuous(labels = scales::percent) +
theme_minimal()
data_clean <- data %>%
filter(!is.na(s1q3), !is.na(wt_wave4)) %>%
mutate(s1q3 = as_factor(s1q3))
design <- svydesign(
ids = ~1,
weights = ~wt_wave4,
data = data_clean
)
res <- svymean(~s1q3, design)
resultats_parente <- data.frame(
modalite = names(res),
proportion = coef(res),
IC_lower = confint(res)[,1],
IC_upper = confint(res)[,2]
) %>%
mutate(
modalite = gsub("s1q3", "", modalite),
proportion_pct = scales::percent(proportion, accuracy = 0.1),
IC_text = paste0("[",
scales::percent(IC_lower, accuracy = 0.1),
" ; ",
scales::percent(IC_upper, accuracy = 0.1),
"]")
)
resultats_parente %>%
select(modalite, proportion_pct, IC_text) %>%
rename(
`Lien de parenté` = modalite,
Proportion = proportion_pct,
`IC 95%` = IC_text
)
resultats_parente %>%
ggplot(aes(x = proportion, y = fct_reorder(modalite, proportion))) +
geom_col(fill = "darkblue") +
geom_errorbar(aes(xmin = IC_lower, xmax = IC_upper), width = 0.2) +
labs(
title = "Proportions des liens de parenté (pondérées) avec IC à 95%",
x = "Proportion",
y = ""
) +
scale_x_continuous(labels = scales::percent) +
theme_minimal()
