#==================================================
#install.packages("patchwork") #installation des packages necessaires
#install.packages('coin')
library(haven)
library(dplyr)
library(ggplot2)
library(apyramid)
library(naniar)
library(gtsummary)
library(rstatix)
library(PropCIs)
library(patchwork)
library(ggplot2)
sect1_harvestw4 <- read_dta("data/raw/NGA_2018_GHSP-W4_v03_M_Stata12/sect1_harvestw4.dta")
View(sect1_harvestw4)
str(sect1_harvestw4)
glimpse(sect1_harvestw4)
summary(sect1_harvestw4)
# Vérifier les doublons sur hhid + indiv---------------------
duplicates1 <- sect1_harvestw4 %>%
group_by(hhid, indiv) %>%
filter(n() > 1) %>%
ungroup()
duplicates2 <- sect1_harvestw4 %>%
group_by(hhid, indiv) %>%
filter(n() > 1) %>%
ungroup()
duplicates3 <- sect1_harvestw4 %>%
group_by(hhid, indiv) %>%
filter(n() > 1) %>%
ungroup()
duplicates4 <- sect1_harvestw4 %>%
group_by(hhid, indiv) %>%
filter(n() > 1) %>%
ungroup()
rm(duplicates1)
rm(duplicates2)
rm(duplicates3)
rm(duplicates4)
#HISTOGRAMME----------------------------------
# Statistiques descriptives
# Renommer s1q4 en age si nécessaire
#if("s1q4" %in% names(sect1_harvestw4)) {
# sect1_harvestw4 <- sect1_harvestw4 %>% rename(age = s1q4)
#}
age_stats <- sect1_harvestw4 %>%
summarise(
moyenne = mean(s1q4, na.rm = TRUE),
mediane = median(s1q4, na.rm = TRUE),
Q1 = quantile(s1q4, 0.25, na.rm = TRUE),
Q3 = quantile(s1q4, 0.75, na.rm = TRUE),
min = min(s1q4, na.rm = TRUE),
max = max(s1q4, na.rm = TRUE),
sd = sd(s1q4, na.rm = TRUE),
cv = sd/moyenne * 100,  # Coefficient de variation en %
asymetrie = (3*(moyenne - mediane))/sd  # Approximation de l'asymétrie
)
print(age_stats)
# Histogramme-----------------------------------------
library(ggplot2)
p1 <- ggplot(sect1_harvestw4, aes(x = s1q4)) +
geom_histogram(binwidth = 5, fill = "steelblue", color = "white", alpha = 0.7) +
labs(title = "Distribution de l'âge des membres",
x = "Âge (ans)", y = "Effectif") +
geom_vline(xintercept = age_stats$moyenne, color = "red", linetype = "dashed", linewidth = 1) +
geom_vline(xintercept = age_stats$mediane, color = "green", linetype = "dashed", linewidth = 1) +
annotate("text", x = age_stats$moyenne+2, y = Inf, label = "Moyenne", vjust = 2, color = "red") +
annotate("text", x = age_stats$mediane+2, y = Inf, label = "Médiane", vjust = 2, color = "green")
#Box_plot----------------------------------------------
p2 <- ggplot(sect1_harvestw4, aes(y = s1q4)) +
geom_boxplot(fill = "steelblue", alpha = 0.7) +
labs(title = "Boxplot de l'âge", y = "Âge (ans)") +
theme(axis.text.x = element_blank(), axis.ticks.x = element_blank())
#ou bien
p2b <- ggplot(sect1_harvestw4, aes(x = "", y = s1q4)) + geom_boxplot()
# Test de normalité de Shapiro-Wilk-------------------------------
set.seed(123)
age_sample <- sample(sect1_harvestw4$s1q4[!is.na(sect1_harvestw4$s1q4)], min(5000, sum(!is.na(sect1_harvestw4$s1q4))))
shapiro_test <- shapiro.test(age_sample)
print(shapiro_test)
#3-Pyramide des âges----------------------------------------------
#regroupement des ages d'abord
library(dplyr)
sect1_harvestw4 <- sect1_harvestw4 %>%
mutate(
age_group = cut(
s1q4,     # la colonne avec l'âge
breaks = c(0, 4, 9, 14, 19, 24, 29, 34, 39, 44, 49, 54, 59, 64, Inf),
labels = c("0-4","5-9","10-14","15-19","20-24","25-29",
"30-34","35-39","40-44","45-49","50-54","55-59","60-64","65+"),
right = TRUE
)
)
library(dplyr)
library(haven)  # pour as_factor()
sect1_harvestw4 <- sect1_harvestw4 %>%
mutate(s1q2 = as_factor(s1q2))  # transforme en factor avec labels "MALE" / "FEMALE"
library(apyramid)
pyramide_apy <- age_pyramid(
data = sect1_harvestw4,
age_group = "age_group",
split_by  = "s1q2"
) + labs(title = "Pyramide des âges - Vague 4 (Harvest)")
pyramide_apy  # Affiche le plot
# Commentaire sur la structure d'ensemble
cat("Commentaire: La pyramide montre une base relativement large (population jeune),
caractéristique des pays en développement. On observe un rétrécissement progressif
avec l'âge, typique d'une population avec une mortalité encore élevée.\n")
# Création de toutes les variables nécessaires proprement
sect1_harvestw4 <- sect1_harvestw4 %>%
mutate(
# Conversion des facteurs
sexe_fct = as_factor(s1q2),
lien_fct = as_factor(s1q3),
age = s1q4,
# Groupes d'âge pour la pyramide
age_group = cut(age,
breaks = seq(0, 100, by = 5),
right = FALSE,
labels = paste(seq(0, 95, by = 5), seq(4, 99, by = 5), sep = "-"))
)
# Analyse des fréquences
freq_lien <- sect1_harvestw4 %>%
filter(!is.na(lien_fct)) %>%
count(lien_fct) %>%
mutate(
proportion = n / sum(n) * 100,
ci_lower = sapply(n, function(x) binom.test(x, sum(n))$conf.int[1]) * 100,
ci_upper = sapply(n, function(x) binom.test(x, sum(n))$conf.int[2]) * 100
) %>%
arrange(desc(proportion))
print(freq_lien)
# Graphique
ggplot(freq_lien, aes(x = proportion, y = reorder(lien_fct, proportion))) +
geom_col(fill = "steelblue", alpha = 0.7) +
geom_errorbar(aes(xmin = ci_lower, xmax = ci_upper), width = 0.2) +
labs(title = "Distribution du lien de parenté avec le chef de ménage",
x = "Proportion (%)",
y = "Lien de parenté") +
theme_minimal()
#5.Taille moyenne des ménages-------------------------------------------
#install.packages('coin')
library(coin)
# 5. Calculer la taille des ménages directement
sect1_harvestw4 <- sect1_harvestw4 %>%
group_by(hhid) %>%
mutate(taille_menage = n()) %>%  # Crée la taille pour chaque ligne
ungroup() %>%
mutate(
zone = case_when(
sector == 1 ~ "Rural",
sector == 2 ~ "Urbain",
TRUE ~ NA_character_
)
)
# Boxplot groupé
ggplot(sect1_harvestw4, aes(x = zone, y = taille_menage, fill = zone)) +
geom_boxplot(alpha = 0.7) +
scale_fill_manual(values = c("Rural" = "forestgreen", "Urbain" = "orange")) +
labs(title = "Taille des ménages par zone", x = "Zone", y = "Taille du ménage") +
theme_minimal() +
theme(legend.position = "none")
# Test de Wilcoxon-Mann-Whitney
wilcox.test(taille_menage ~ zone, data = sect1_harvestw4)
# Taille d'effet r
library(rstatix)
sect1_harvestw4 %>% wilcox_effsize(taille_menage ~ zone)
# 6. Tableau récapitulatif----------------------------------------------------
# 6. Tableau récapitulatif gtsummary stratifié par zone avec p-valeurs
library(gtsummary)
sect1_harvestw4 %>%
mutate(
zone = ifelse(sector == 1, "Rural", "Urbain"),
sexe = factor(s1q2, labels = c("Homme", "Femme")),
age = s1q4
) %>%
group_by(hhid) %>%
mutate(taille_menage = n()) %>%
ungroup() %>%
select(zone, age, sexe, taille_menage) %>%
tbl_summary(
by = zone,
statistic = list(
all_continuous() ~ "{mean} ({sd})",
all_categorical() ~ "{n} ({p}%)"
),
digits = all_continuous() ~ 1,
label = list(age = "Âge", sexe = "Sexe", taille_menage = "Taille du ménage")
) %>%
add_p() %>%
add_overall()
