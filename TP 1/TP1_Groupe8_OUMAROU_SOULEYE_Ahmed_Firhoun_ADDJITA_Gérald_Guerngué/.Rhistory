# Packages
library(dplyr)
library(ggplot2)
library(haven)
library(gtsummary)
library(PropCIs)
# =========================
# 1️⃣ Pyramide des âges
# =========================
pyramid_data <- processed_w4 %>%
filter(!is.na(harvest_s1q4), !is.na(harvest_s1q2), harvest_s1q4 >=0, harvest_s1q4 <=110) %>%
mutate(
groupe_age = cut(harvest_s1q4,
breaks = c(0,5,10,15,20,25,30,35,40,45,50,55,60,65,70,75,80,Inf),
labels = c("0-4","5-9","10-14","15-19","20-24","25-29","30-34",
"35-39","40-44","45-49","50-54","55-59","60-64",
"65-69","70-74","75-79","80+"),
right = FALSE),
sexe_label = factor(as.numeric(harvest_s1q2), levels = c(1,2), labels = c("Hommes","Femmes"))
) %>%
filter(!is.na(groupe_age))
n_total_pyr <- nrow(pyramid_data)
pyr_count <- pyramid_data %>%
count(groupe_age, sexe_label) %>%
mutate(
pct_plot = ifelse(sexe_label=="Hommes", -n/n_total_pyr*100, n/n_total_pyr*100),
label_pct = paste0(abs(round(pct_plot,1)), "%")
)
y_lim <- max(abs(pyr_count$pct_plot)) * 1.28
ggplot(pyr_count, aes(x=groupe_age, y=pct_plot, fill=sexe_label)) +
geom_col(width=0.88, alpha=0.92) +
geom_text(aes(label=label_pct),
hjust=ifelse(pyr_count$sexe_label=="Hommes",1.18,-0.18),
size=3, color="#2D3436", fontface="bold") +
scale_fill_manual(values=c("Hommes"="#4ECDC4","Femmes"="#FF6B6B"), name="Sexe") +
scale_y_continuous(labels=function(x) paste0(abs(x),"%"), limits=c(-y_lim,y_lim)) +
coord_flip() +
geom_hline(yintercept=0, color="#2D3436", linewidth=0.9) +
labs(title="Pyramide des âges des membres des ménages",
x="Groupe d'âge (années)", y="Part de la population (%)",
caption="Source : Nigeria GHS Panel Wave 4 (2018)") +
theme_minimal() +
theme(legend.position="none")
# =========================
# 2️⃣ Distribution lien de parenté
# =========================
df_lien <- processed_w4 %>%
filter(!is.na(harvest_s1q3))
freq_table <- df_lien %>%
group_by(harvest_s1q3) %>%
summarise(n=n(), .groups="drop") %>%
mutate(total=sum(n),
prop=n/total) %>%
rowwise() %>%
mutate(
prop_ci = list(exactci(n,total,conf.level=0.95)$conf.int),
prop_lower = prop_ci[[1]],
prop_upper = prop_ci[[2]]
) %>%
ungroup()
ggplot(freq_table, aes(x=reorder(harvest_s1q3,n), y=prop)) +
geom_bar(stat="identity", fill="steelblue") +
geom_errorbar(aes(ymin=prop_lower, ymax=prop_upper), width=0.2) +
geom_text(aes(label=paste0(round(prop*100,1),"%")), hjust=-0.15, size=3, color="#2D3436") +
coord_flip() +
scale_y_continuous(labels=scales::percent_format(accuracy=1),
limits=c(0,max(freq_table$prop)*1.15)) +
labs(title="Distribution du lien de parenté (Vague 4)",
x="Lien de parenté", y="Proportion (IC 95%)") +
theme_minimal()
# =========================
# 3️⃣ Taille des ménages + boxplot + Wilcoxon
# =========================
menages <- processed_w4 %>%
filter(!is.na(hhid), sector %in% c(1,2)) %>%
group_by(hhid, sector) %>%
summarise(taille_menage=n(), .groups="drop") %>%
mutate(zone_label=factor(sector, levels=c(1,2), labels=c("Rurale","Urbaine")))
# Boxplot
ggplot(menages, aes(x=zone_label, y=taille_menage, fill=zone_label)) +
geom_boxplot() +
labs(title="Taille des ménages selon la zone", x="Zone", y="Taille du ménage") +
scale_fill_manual(values=c("Rurale"="lightgreen","Urbaine"="lightblue")) +
theme_minimal()
# Test Wilcoxon-Mann-Whitney
wilcox_res <- wilcox.test(taille_menage ~ zone_label, data=menages, exact=FALSE)
library(dplyr)
library(gtsummary)
