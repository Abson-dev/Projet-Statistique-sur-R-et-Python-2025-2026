# Préparer les données
gt_data <- processed_w4 %>%
filter(!is.na(harvest_s1q4), !is.na(harvest_s1q2), sector %in% c(1,2)) %>%
mutate(
zone_label = factor(sector, levels = c(1,2), labels = c("Rural","Urbain")),
sexe_label = factor(as.numeric(harvest_s1q2), levels = c(1,2), labels = c("Homme","Femme")),
groupe_age = cut(harvest_s1q4,
breaks = c(0,15,30,45,60,Inf),
labels = c("0-14 ans","15-29 ans","30-44 ans","45-59 ans","60+"),
right = FALSE)
) %>%
group_by(hhid, zone_label) %>%
mutate(taille_menage = n()) %>%
ungroup() %>%
select(zone_label, harvest_s1q4, sexe_label, groupe_age, taille_menage) %>%
filter(!is.na(zone_label))
# Vérifier qu'on a bien 2 niveaux pour zone
if(length(unique(gt_data$zone_label)) == 2){
tableau_gt <- gt_data %>%
tbl_summary(
by = zone_label,
label = list(
harvest_s1q4  ~ "Âge (années)",
sexe_label    ~ "Sexe",
groupe_age    ~ "Groupe d'âge",
taille_menage ~ "Taille du ménage"
),
statistic = list(
all_continuous()  ~ "{mean} ({sd}) | Méd.={median} [IQR:{p25}-{p75}]",
all_categorical() ~ "{n} ({p}%)"
),
digits = list(all_continuous() ~ 2),
missing = "ifany",
missing_text = "Valeur manquante"
) %>%
add_p(
test = list(
all_continuous()  ~ "wilcox.test",
all_categorical() ~ "chisq.test"
),
pvalue_fun = ~style_pvalue(.x, digits = 3)
) %>%
add_overall() %>%
add_n() %>%
bold_labels() %>%
italicize_levels() %>%
modify_header(label ~ "**Variable**") %>%
modify_caption(
paste0("**Tableau 1.** Caractéristiques démographiques par zone de résidence\n",
"Nigeria GHS Panel Wave 4 (2018) | N = ", format(nrow(gt_data), big.mark=" "))
)
tableau_gt
} else {
stop("La variable zone_label n'a pas exactement 2 niveaux valides. Impossible de créer le tableau.")
}
